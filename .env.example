# ============================================
# Forest observation and analysis system
# Environment Configuration
# ============================================

# Google Earth Engine
GEE_PROJECT_ID=your-gee-project-id
GEE_SERVICE_ACCOUNT_KEY=  # Optional: path to service account JSON

# Server Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Default AOI (Amazon Rainforest)
DEFAULT_AOI_WEST=-60.0
DEFAULT_AOI_SOUTH=-3.0
DEFAULT_AOI_EAST=-59.0
DEFAULT_AOI_NORTH=-2.0

# Logging
LOG_LEVEL=INFO

# Demo Mode (set to true to use synthetic data)
DEMO_MODE=false
